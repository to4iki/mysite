---
import type { BlogPost } from "../lib/blog";
import FormattedDate from "./FormattedDate.astro";

type Props = {
  posts: BlogPost[];
};

const { posts } = Astro.props;
---

<ul class="list-none m-0 p-0">
  {
    posts.map((post) => (
      <li class="py-3 border-b border-divider">
        <a
          href={`/blog/${post.id}/`}
          class="flex items-baseline gap-6 no-underline max-md:flex-col max-md:gap-1 hover:text-primary"
        >
          <span class="text-base font-bold shrink-0 min-w-32 tabular-nums max-md:min-w-0">
            <FormattedDate date={post.data.pubDate} />
          </span>
          <span class="text-lg font-semibold max-md:text-base">{post.data.title}</span>
        </a>
      </li>
    ))
  }
</ul>
