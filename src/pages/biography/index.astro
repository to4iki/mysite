---
import BiographySection from "../../components/BiographySection.astro";
import GitHubIcon from "../../components/icons/GitHubIcon.astro";
import XIcon from "../../components/icons/XIcon.astro";
import PageHeaderText from "../../components/PageHeaderText.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../../consts";
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title={`Biography | ${SITE_TITLE}`} description={SITE_DESCRIPTION}>
  <PageHeaderText>BIOGRAPHY</PageHeaderText>
    <section class="flex items-center gap-6 mb-12 max-md:flex-col max-md:items-center max-md:text-center">
      <img
        src="/biography.avif"
        alt="Toshiki Takezawa のプロフィール写真"
        width="128"
        height="128"
        class="w-32 h-32 rounded-2xl object-cover shrink-0 max-md:w-28 max-md:h-28"
      />
      <div>
        <h2 class="text-4xl font-bold mb-2 max-md:text-3xl">Toshiki Takezawa (@to4iki)</h2>
        <div class="flex items-center gap-3 max-md:justify-center" aria-label="ソーシャルリンク">
          <a
            href="https://x.com/to4iki"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="X のプロフィール (外部サイトへ移動)"
            class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-foreground/15 text-foreground transition-colors duration-200 hover:border-primary hover:text-primary"
          >
            <XIcon />
          </a>
          <a
            href="https://github.com/to4iki"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub のプロフィール (外部サイトへ移動)"
            class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-foreground/15 text-foreground transition-colors duration-200 hover:border-primary hover:text-primary"
          >
            <GitHubIcon />
          </a>
        </div>
      </div>
    </section>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-x-4 gap-y-8">
      <BiographySection
        title="PLATFORM"
        items={[
          { label: "Zenn", url: "https://zenn.dev/to4iki" },
          { label: "note", url: "https://note.com/tto4iki" },
          { label: "sizu", url: "https://sizu.me/to4iki" },
          { label: "SpeakerDeck", url: "https://speakerdeck.com/to4iki" },
        ]}
      />
      <BiographySection
        title="OTHER"
        items={[
          { label: "Qiita", url: "https://qiita.com/to4iki" },
          { label: "hatenablog", url: "https://to4iki.hatenablog.jp" },
          { label: "Medium", url: "https://medium.com/@to4iki" },
        ]}
      />
      <BiographySection
        title="RESUME"
        items={[
          { label: "Wantedly", url: "https://www.wantedly.com/id/to4iki" },
        ]}
      />
      <BiographySection
        title="BOOK"
        items={[
          { label: "WEB+DB PRESS Vol.104", url: "https://www.amazon.co.jp/dp/4774196886" },
          { label: "AbemaTV iOS Tech Book", url: "https://techbookfest.org/product/261920001" },
        ]}
      />
    </div>
</BaseLayout>
