---
import BlogPostList from "../../components/BlogPostList.astro";
import PageHeaderText from "../../components/PageHeaderText.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../../consts";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  getVisibleBlogPosts,
  sortBlogPostsByPubDateDesc,
} from "../../lib/blog";

const posts = sortBlogPostsByPubDateDesc(await getVisibleBlogPosts());
---

<BaseLayout title={`Blog | ${SITE_TITLE}`} description={SITE_DESCRIPTION}>
  <PageHeaderText>BLOG</PageHeaderText>
  <BlogPostList posts={posts} />
</BaseLayout>
